    "semantic:index-jobs": "bun run scripts/run-semantic-index-jobs.ts",
    "vector-store:smoke": "bun run scripts/run-vector-store-smoke.ts",
    "oidc:keycloak:smoke": "bash scripts/run-oidc-keycloak-smoke.sh",
    "saml:keycloak:smoke": "bash scripts/run-saml-keycloak-smoke.sh",
    "postinstall": "prisma generate",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui"
  },
