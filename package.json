{
  "name": "jpad",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev --turbopack\" \"bun run src/server/ws.ts\"",
    "dev:next": "next dev --turbopack",
    "dev:ws": "bun run src/server/ws.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bunx playwright test",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:migrate": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "backup:run": "bun run scripts/run-backup.ts",
    "restore-drill:run": "bun run scripts/run-restore-drill.ts",
    "retention:run": "bun run scripts/run-retention.ts",
    "audit-log:deliveries": "bun run scripts/run-audit-log-deliveries.ts",
    "audit-log:delivery:smoke": "bun run scripts/run-audit-log-delivery-smoke.ts",
    "upload-security:smoke": "bun run scripts/run-upload-security-smoke.ts",
    "upload-dlp:smoke": "bun run scripts/run-upload-dlp-smoke.ts",
